{
  "name": "qa-insights",
  "version": "1.0.0",
  "description": "Herramienta interna de QA: test impact analysis y detección de flakiness.",
  "author": "Fernando Carballo",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "demo:impact": "tsx src/cli.ts impact --project sample-project --changed sample-project/src/math.ts",
    "demo:flaky": "tsx src/cli.ts flaky --results sample-results"
  },
  "keywords": ["qa-tooling", "test-impact-analysis", "flaky-detection", "sdet", "developer-experience"],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
